:80 {
	handle /health {
		header Content-Type application/json
		respond "{\"status\":\"ok\"}" 200
	}

	handle_path /readings* {
		reverse_proxy ingestion:3001
	}

	handle /dashboard {
		reverse_proxy dashboard-api:3000 {
			lb_policy round_robin
		}
	}

	handle_path /dashboard/* {
		reverse_proxy dashboard-api:3000 {
			lb_policy round_robin
		}
	}

	handle /alerts* {
		reverse_proxy alert-service:3000
	}

	handle /sensors* {
		reverse_proxy sensor-registry-service:3000 {
			lb_policy round_robin
		}
	}

	handle /devices* {
		reverse_proxy device-management-service:3000
	}

	# Default 404 for unknown paths
	handle {
		respond "Not Found" 404
	}
}
